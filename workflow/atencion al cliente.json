    {
      "parameters": {
        "operation": "executeQuery",
        "query": "SELECT o.id, o.estado, o.fecha_creacion, o.fecha_estimada_entrega, o.tracking_code, p.nombre as producto FROM orders o LEFT JOIN order_items oi ON o.id = oi.order_id LEFT JOIN products p ON oi.product_id = p.id WHERE o.id = '{{ $json.order_id }}' OR o.customer_phone = '{{ $json.user }}' ORDER BY o.fecha_creacion DESC LIMIT 1;",
        "options": {}
      },
