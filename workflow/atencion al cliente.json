        },
        "sendBody": true,
        "specifyBody": "json",
        "jsonBody": "={\n  \"model\": \"gpt-4o-mini\",\n  \"messages\": [\n    {\n      \"role\": \"system\",\n      \"content\": \"Eres un clasificador de mensajes de atención al cliente. Tu ÚNICA función es analizar el mensaje y devolver un JSON con exactamente estos campos:\\n{\\n  \\\"intent\\\": \\\"FAQ\\\" | \\\"ESTADO_PEDIDO\\\" | \\\"RECLAMO\\\" | \\\"GENERAL\\\",\\n  \\\"order_id\\\": string | null,\\n  \\\"urgente\\\": boolean\\n}\\n\\nReglas:\\n- FAQ: preguntas sobre productos, precios, horarios, políticas.\\n- ESTADO_PEDIDO: consultas sobre estado de pedido o envío. Extrae el número de pedido en order_id si lo menciona.\\n- RECLAMO: quejas, problemas, solicitudes de reembolso, experiencias negativas.\\n- GENERAL: todo lo que no encaja en las categorías anteriores.\\n- urgente: true solo si contiene palabras como urgente, ya, inmediato, emergencia, o el tono es muy crítico.\\n\\nDevuelve SOLO el JSON. Sin texto adicional, sin markdown.\"\n    },\n    {\n      \"role\": \"user\",\n      \"content\": \"{{ $json.message }}\"\n    }\n  ]\n}",
        "options": {}
      },
      "name": "IA - Clasificador",
      "type": "n8n-nodes-base.httpRequest",
      "position": [
        2016,
        1008
      ],
      "id": "395f36ac-6342-402c-9505-ee08ff77348d",
      "typeVersion": 4.4
    },
    {
      "parameters": {
        "functionCode": "let raw = $json.choices?.[0]?.message?.content || '';\nraw = raw.replace(/```json|```/g, '').trim();\nlet clasificacion;\ntry {\n  clasificacion = JSON.parse(raw);\n} catch(e) {\n  clasificacion = { intent: 'GENERAL', order_id: null, urgente: false };\n}\nconst origen = $('Merge B (+Gmail)').first().json;\nreturn [{\n  intent: clasificacion.intent || 'GENERAL',\n  order_id: clasificacion.order_id || null,\n  urgente: clasificacion.urgente || false,\n  canal: origen.canal,\n  user: origen.user,\n  message: origen.message,\n  nombre: origen.nombre || 'Cliente',\n  subject: origen.subject || '',\n  threadId: origen.threadId || ''\n}];"
      },
