    {
      "parameters": {
        "functionCode": "const rows = $input.all();\nconst faqs = rows.map(r => r.json).filter(r => r.pregunta);\nconst ctx = faqs.length > 0\n  ? faqs.map(f => `P: ${f.pregunta}\\nR: ${f.respuesta}`).join('\\n\\n')\n  : 'No se encontraron FAQs relevantes. Responde de forma general y ofrece contacto humano.';\nconst prev = $('Switch Intent').first().json;\nreturn [{ ...prev, contexto_db: ctx, rama: 'FAQ' }];"
      },
      "name": "Preparar Contexto FAQ",
      "type": "n8n-nodes-base.function",
      "position": [
