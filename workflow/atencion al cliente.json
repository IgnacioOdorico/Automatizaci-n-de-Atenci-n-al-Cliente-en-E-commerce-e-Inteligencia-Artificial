      "parameters": {
        "functionCode": "const respuesta = $json.choices?.[0]?.message?.content || 'Lo sentimos, no pudimos procesar tu consulta. Por favor intentá de nuevo.';\nconst prev = $('Merge E (todas ramas)').first().json;\nreturn [{\n  canal: prev.canal,\n  user: prev.user,\n  nombre: prev.nombre,\n  rama: prev.rama,\n  urgente: prev.urgente,\n  ticket_id: prev.ticket_id || null,\n  subject: prev.subject || '',\n  threadId: prev.threadId || '',\n  respuesta: respuesta.trim()\n}];"
      },
