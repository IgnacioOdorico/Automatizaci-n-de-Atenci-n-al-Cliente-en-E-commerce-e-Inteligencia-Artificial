    {
      "parameters": {
        "functionCode": "const body = $json.body || $json;\nconst entry = body.entry?.[0]?.changes?.[0]?.value;\nconst msg = entry?.messages?.[0];\nif (!msg) throw new Error('No se encontró mensaje de WhatsApp');\nreturn [{\n  user: msg.from,\n  message: msg.text?.body || '',\n  canal: 'whatsapp',\n  nombre: entry?.contacts?.[0]?.profile?.name || 'Cliente'\n}];"
      },
