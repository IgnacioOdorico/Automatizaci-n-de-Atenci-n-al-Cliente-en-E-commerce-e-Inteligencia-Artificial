    {
      "parameters": {
        "functionCode": "const rows = $input.all();\nconst pedido = rows[0]?.json;\nlet ctx;\nif (pedido && pedido.id) {\n  ctx = `Pedido #${pedido.id}\\nEstado: ${pedido.estado}\\nProducto: ${pedido.producto || 'N/D'}\\nFecha creación: ${pedido.fecha_creacion}\\nEntrega estimada: ${pedido.fecha_estimada_entrega || 'No disponible'}\\nTracking: ${pedido.tracking_code || 'Sin tracking aún'}`;\n} else {\n  ctx = 'No se encontró ningún pedido asociado a este cliente o número de pedido.';\n}\nconst prev = $('Switch Intent').first().json;\nreturn [{ ...prev, contexto_db: ctx, rama: 'ESTADO_PEDIDO' }];"
      },
